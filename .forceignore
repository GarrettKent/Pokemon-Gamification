# List files or directories below to ignore them when running source push/pull/deploy/retrieve.
# https://developer.salesforce.com/docs/atlas.en-us.sfdx_dev.meta/sfdx_dev/sfdx_dev_exclude_source.htm

package.xml

# Keep empty-folder placeholders out of deployments
**/.gitkeep

# LWC configuration files
**/jsconfig.json
**/.eslintrc.json

# LWC Jest
**/__tests__/**

# Local reference mirror of the LSC org code — never deploy/retrieve it
refs/
