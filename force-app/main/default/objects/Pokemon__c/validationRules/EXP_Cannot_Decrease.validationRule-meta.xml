<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>EXP_Cannot_Decrease</fullName>
    <active>true</active>
    <errorConditionFormula>ISCHANGED(EXP_Points__c) &amp;&amp; EXP_Points__c &lt; PRIORVALUE(EXP_Points__c)</errorConditionFormula>
    <errorDisplayField>EXP_Points__c</errorDisplayField>
    <errorMessage>A Pokemon's EXP cannot decrease.</errorMessage>
</ValidationRule>
